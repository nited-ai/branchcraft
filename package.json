{
  "name": "branchcraft",
  "version": "0.0.1",
  "description": "Visual Git for solo devs and vibe-coding teams. Worktree-aware, AI-session-aware, with a drag-and-drop simulator that previews any command before you run it.",
  "type": "module",
  "license": "MIT",
  "author": "nited-ai",
  "homepage": "https://github.com/nited-ai/branchcraft#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/nited-ai/branchcraft.git"
  },
  "bugs": "https://github.com/nited-ai/branchcraft/issues",
  "keywords": [
    "git",
    "git-gui",
    "worktree",
    "claude-code",
    "codex",
    "aider",
    "ai-coding",
    "git-graph",
    "git-visualization"
  ],
  "engines": {
    "node": ">=20.0.0"
  },
  "bin": {
    "branchcraft": "./bin/branchcraft.js"
  },
  "files": [
    "bin/",
    "dist/"
  ],
  "scripts": {
    "dev": "concurrently -n server,web -c yellow,cyan \"npm run dev:server\" \"npm run dev:web\"",
    "dev:server": "tsx watch src/server/index.ts",
    "dev:web": "vite",
    "build": "npm run build:web && npm run build:server",
    "build:web": "vite build",
    "build:server": "tsc -p tsconfig.server.json",
    "start": "node dist/server/index.js",
    "typecheck": "tsc -p tsconfig.json --noEmit && svelte-check",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@hono/node-server": "^1.13.0",
    "chokidar": "^4.0.0",
    "hono": "^4.6.0"
  },
  "devDependencies": {
    "@sveltejs/vite-plugin-svelte": "^4.0.0",
    "@tsconfig/node20": "^20.1.4",
    "@types/node": "^22.0.0",
    "concurrently": "^9.0.0",
    "svelte": "^5.0.0",
    "svelte-check": "^4.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0",
    "vite": "^5.4.0",
    "vitest": "^2.1.0"
  }
}
